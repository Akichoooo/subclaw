# subclaw environment template.
#
# This file is loaded by docker-compose.yml and by the proxy when started
# natively. Copy this to `.env` and fill in real values.
#
# NEVER commit a real .env to git. The .env.example file is safe to commit
# and is the only file that should appear in version control.

# === Provider API keys ===
# Pass at least one. The proxy will hot-load keys.json and pick from any
# provider you've configured there.

# Anthropic (Claude Opus, Sonnet, Haiku)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4o, GPT-4o-mini, o1, o3, etc.)
# OPENAI_API_KEY=sk-...

# OpenRouter (routes to 50+ models behind one key)
# OPENROUTER_API_KEY=sk-or-...

# DeepSeek
# DEEPSEEK_API_KEY=sk-...

# Moonshot Kimi
# MOONSHOT_API_KEY=sk-...

# GLM (Zhipu)
# GLM_API_KEY=...

# === Proxy configuration ===

# Port the FastAPI proxy listens on. Default: 4748
# PROXY_PORT=4748

# Log level: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# === Budget circuit breaker ===
# Hard cap on per-session spend (USD). Set to 0 to disable.
# MAX_SPEND_PER_SESSION_USD=2.0

# Hard cap on per-day spend (USD). Set to 0 to disable.
# MAX_SPEND_PER_DAY_USD=10.0

# === Network ===
# If your upstream is behind a corporate proxy, set HTTPS_PROXY env var.
# HTTPS_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1
