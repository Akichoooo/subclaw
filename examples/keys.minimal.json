{
  "_comment": "Example: minimum viable setup. One Anthropic key, cheap model only. Good for first-time users testing the proxy. Copy to proxy/keys.json and replace REPLACE_WITH_* placeholders.",
  "keys": [
    {
      "key": "REPLACE_WITH_ANTHROPIC_KEY",
      "url": "https://api.anthropic.com",
      "model_id": "claude-3-haiku-20240307",
      "alias": "haiku-cheap",
      "provider": "anthropic",
      "protocol": "anthropic",
      "tier": "cheap",
      "capabilities": {
        "context_window": 200000,
        "max_output": 4096,
        "supports_tools": true
      },
      "limits": {
        "max_rpm": 50,
        "max_tpm": 50000,
        "max_concurrent": 5
      },
      "cost_per_1m_in": 0.25,
      "cost_per_1m_out": 1.25
    }
  ],
  "global_proxy_settings": {
    "circuit_breaker": {
      "max_spend_per_session_usd": 2.0,
      "max_spend_per_day_usd": 10.0
    },
    "security": {
      "mask_secrets_in_payload": true,
      "forbidden_paths": ["**/.env", "**/*.pem"]
    },
    "features": {
      "auto_prompt_caching": true
    }
  }
}
